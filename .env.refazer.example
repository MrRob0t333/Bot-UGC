REFAZER_DISCORD_TOKEN=
REFAZER_CLIENT_ID=
REFAZER_GUILD_ID=

# Liga um teste completo sem chamar Nano Banana Pro nem Tripo AI.
REFAZER_MOCK_IA=true

# Opcional: use cargos diferentes no bot laboratorio.
REFAZER_ELITE_ROLE=1523463473328292013
REFAZER_PREMIUM_ROLE=1521989120745013459
REFAZER_NORMAL_ROLE=1521959526394237089
REFAZER_FREE_ROLE=1523104972068356187
REFAZER_ADMIN_ROLE=1522293475801038868
REFAZER_AFFILIATE_ROLE=1523108378346520607

# Afiliados.
REFAZER_AFFILIATE_WALLET_RATE=0.10
REFAZER_AFFILIATE_SERVICE_RATE=0.05
REFAZER_AFFILIATE_SUBSCRIPTION_RATE=0.20
REFAZER_AFFILIATE_SUBSCRIPTION_BOOST_RATE=0.50
REFAZER_AFFILIATE_SUBSCRIPTION_BOOST_CLIENTS=100

# Margem e custo estimado por modelo. Se a API ficar mais cara,
# aumente estes valores para o bot manter pelo menos R$10 de lucro.
REFAZER_MIN_PROFIT_BRL=10
REFAZER_API_COST_MODEL_STANDARD_BRL=7
REFAZER_API_COST_MODEL_NO_TEXTURE_BRL=6
REFAZER_API_COST_MODEL_HD_BRL=9
REFAZER_API_COST_MULTIVIEW_EXTRA_BRL=2
REFAZER_API_COST_LOWPOLY_EXTRA_BRL=1
REFAZER_API_COST_ENHANCEMENT_ECONOMY_BRL=1
REFAZER_API_COST_ENHANCEMENT_STANDARD_BRL=2
REFAZER_API_COST_ENHANCEMENT_PREMIUM_BRL=5

# Promocao de lancamento para modelos de IA.
# Primeiros 3 modelos entregues por usuario: R$15. Depois: R$20.
REFAZER_AI_MODEL_PROMO_ENABLED=true
REFAZER_AI_MODEL_PROMO_FIRST_LIMIT=3
REFAZER_AI_MODEL_PROMO_FIRST_PRICE_BRL=15
REFAZER_AI_MODEL_PROMO_REGULAR_PRICE_BRL=20

# Reusa seu cookie Roblox se precisar acessar assets protegidos.
ROBLOSECURITY=
ROBLOSECURITY_2=
ROBLOSECURITY_3=

# Roupas classicas: limites para nao tomar rate limit do Roblox.
REFAZER_FREE_CLOTHING_DAILY_LIMIT=6
REFAZER_FREE_CLOTHING_PRICE=10
REFAZER_BASIC_CLOTHING_DAILY_LIMIT=20
REFAZER_BASIC_CLOTHING_PRICE=5
REFAZER_BULK_ITEM_DELAY_MS=3000
REFAZER_BULK_ASSET_LIMIT=15
REFAZER_FREE_BULK_ASSET_LIMIT=3
REFAZER_BASIC_BULK_ASSET_LIMIT=7
REFAZER_PREMIUM_BULK_ASSET_LIMIT=15
REFAZER_ELITE_BULK_ASSET_LIMIT=15
REFAZER_BULK_CLOTHING_LIMIT=15
REFAZER_FREE_BULK_CLOTHING_LIMIT=5
REFAZER_BASIC_BULK_CLOTHING_LIMIT=10
REFAZER_PREMIUM_BULK_CLOTHING_LIMIT=15
REFAZER_ELITE_BULK_CLOTHING_LIMIT=15
REFAZER_ROBLOX_REQUEST_INTERVAL_MS=1200
REFAZER_ROBLOX_RATE_LIMIT_PAUSE_MS=120000
REFAZER_DEFAULT_TEXTURE_TONE=brighter

# Blender usado para gerar as fotos base e exportar GLB.
BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 5.0\blender.exe

# Melhoria/variacao das fotos base com API oficial do Gemini/Nano Banana.
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Fallback opcional para endpoint customizado/revendedor.
# O endpoint deve receber multipart/form-data: image, difference, prompt, model, enhancement.
NANO_BANANA_PRO_ENDPOINT=
NANO_BANANA_PRO_API_KEY=

# Tripo recebe: images, difference, prompt, target.
TRIPO_AI_ENDPOINT=
TRIPO_AI_API_KEY=

# API oficial do Tripo. Use a chave criada no painel API Keys.
TRIPO_API_KEY=
TRIPO_API_BASE=https://api.tripo3d.ai/v2/openapi
TRIPO_MODEL_VERSION=v3.1-20260211
# H3 aceita v3.1-20260211 ou v3.0-20250812. P1 antigo: P1-20260311.
TRIPO_SMART_LOW_POLY=false
TRIPO_GEOMETRY_QUALITY=detailed
TRIPO_QUAD=false

# Hyper3D / Rodin Gen-2. Se HYPER3D_API_KEY existir, o bot usa Hyper3D como motor principal.
HYPER3D_API_KEY=
HYPER3D_API_BASE=https://api.hyper3d.com/api/v2
HYPER3D_TIER=Gen-2
HYPER3D_QUALITY=medium
HYPER3D_MESH_MODE=Quad
HYPER3D_MATERIAL=PBR
HYPER3D_HIGH_PACK=false
HYPER3D_PREVIEW_RENDER=false
HYPER3D_HD_TEXTURE=false

# Ordem oficial da API multiview: front, left, back, right.
REFAZER_MULTIVIEW_UPLOAD_ORDER=frente,esquerda,costas,direita

# Pagamentos. Use stripe por padrao; mercadopago fica de reserva.
PAYMENT_PROVIDER=stripe

# Stripe: Checkout para Velvet Coins e Billing para Basic/Premium.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_URL=https://api.seudominio.com/stripe/webhook
STRIPE_SUCCESS_URL=https://discord.com
STRIPE_CANCEL_URL=https://discord.com

# Mercado Pago: Checkout Pro para Velvet Coins e Assinaturas para Basic/Premium.
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_URL=https://api.seudominio.com/mercadopago/webhook
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_SUCCESS_URL=https://discord.com
MERCADO_PAGO_FAILURE_URL=https://discord.com
MERCADO_PAGO_PENDING_URL=https://discord.com
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=3001
